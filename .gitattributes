* text=auto eol=lf

# Python
*.py text eol=lf diff=python
*.pyi text eol=lf diff=python

# TypeScript / JS
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf

# Docs
*.md text eol=lf
*.mdx text eol=lf

# Config
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf

# Shell
*.sh text eol=lf
Makefile text eol=lf

# Lockfiles (keep LF, do not diff)
pnpm-lock.yaml binary
uv.lock text eol=lf
package-lock.json binary

# Binaries
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary
