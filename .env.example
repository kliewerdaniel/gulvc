# ============================================================================
# Vibe local environment example.
# Copy to .env.local (git-ignored) and edit. `make env` will generate .env.local
# from this template with safe defaults.
# ============================================================================

# ----- General -----
VIBE_ENV=local
VIBE_LOG_LEVEL=info
VIBE_LOG_FORMAT=json
VIBE_PUBLIC_URL=http://localhost:3000
VIBE_API_URL=http://localhost:8080

# ----- Ports (override only on conflicts) -----
API_PORT=8080
WEB_PORT=3000
TEMPORAL_UI_PORT=8233
TEMPORAL_PORT=7233
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MAILHOG_SMTP_PORT=1025
MAILHOG_WEB_PORT=8025
TRAEFIK_PORT=81

# ----- Database -----
DATABASE_URL=postgresql+psycopg://vibe:vibe@localhost:5432/vibe
DATABASE_URL_ASYNC=postgresql+asyncpg://vibe:vibe@localhost:5432/vibe

# ----- Cache / queue -----
REDIS_URL=redis://localhost:6379/0
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=vibe-jobs

# ----- Object storage (MinIO) -----
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=vibe-dev
S3_ACCESS_KEY=vibe
S3_SECRET_KEY=vibe-secret
S3_FORCE_PATH_STYLE=true

# ----- Auth -----
JWT_SIGNING_KEY=dev-only-do-not-use-in-prod-please-32-bytes-min
JWT_ISSUER=vibe.local
JWT_AUDIENCE=vibe-api
JWT_ACCESS_TTL_SECONDS=900
MAGIC_LINK_TTL_SECONDS=900

# ----- Email (MailHog in dev) -----
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM="Vibe <no-reply@vibe.local>"
EMAIL_DELIVERY_MODE=capture   # capture | live

# ----- LLM -----
# If unset, mocks are used.
# LLM_PROVIDER=openai
# LLM_API_KEY=
# LLM_MODE=record              # record | replay | live
# LLM_ALLOWED_MODELS=gpt-4o,claude-3-5-sonnet
LLM_COST_BUDGET_PER_JOB_USD=2.00

# ----- GitHub (M5) -----
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY_PATH=./.local-secrets/github-app.pem
GITHUB_WEBHOOK_SECRET=dev-only-webhook-secret

# ----- Vercel (M5) -----
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_TEAM_SLUG=vibe-dev

# ----- Stripe (M7) -----
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRICE_STARTER=price_placeholder
STRIPE_PRICE_GROWTH=price_placeholder
STRIPE_PRICE_PRO=price_placeholder

# ----- Observability -----
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=
TEMPO_URL=http://localhost:3200
LOKI_URL=http://localhost:3100
SENTRY_DSN=

# ----- Feature flags -----
FEATURE_FLAGS=auth.magic_link,capture.single_url
FEATURE_FLAGS_SOURCE=local

# ----- Operational -----
SHUTDOWN_TIMEOUT_SECONDS=30
WORKER_CONCURRENCY=4
