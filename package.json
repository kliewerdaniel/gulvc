{
  "name": "gouplevelvibecoding",
  "version": "0.0.0",
  "private": true,
  "description": "Autonomous website modernization platform (Vibe).",
  "license": "MIT",
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=9.12.0"
  },
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "clean": "turbo run clean && rm -rf .turbo node_modules",
    "doctor": "node tools/scripts/doctor.mjs",
    "prepare": "husky install || true"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@changesets/changelog-github": "0.5.0",
    "@changesets/cli": "2.27.10",
    "@types/node": "20.16.10",
    "husky": "9.1.6",
    "lint-staged": "15.2.10",
    "semver": "7.6.3",
    "turbo": "2.3.3",
    "typescript": "5.5.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,css}": [
      "biome check --write"
    ],
    "*.{py,pyi}": [
      "ruff format",
      "ruff check --fix"
    ]
  }
}
